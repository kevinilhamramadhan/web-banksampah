rules_version = '2';

// Bank Sampah KKN — rules ini adalah "backend"-nya (tanpa Cloud Functions).
// Prinsip: saldoPoin TIDAK PERNAH bisa diubah bebas oleh siapa pun.
// Perubahan saldo hanya sah lewat dua jalur atomik yang divalidasi silang
// dengan dokumen setoran/penukaran di transaction yang sama (getAfter):
//   1. Ops menambah saldo  ← bersamaan dengan pembuatan dokumen setoran
//   2. Warga mengurangi saldo ← bersamaan dengan konfirmasi penukaran pending→confirmed
service cloud.firestore {
  match /databases/{db}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOps() {
      return signedIn()
        && get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role == 'ops';
    }

    function setoranAfter(id) {
      return getAfter(/databases/$(db)/documents/setoran/$(id)).data;
    }

    function penukaranBefore(id) {
      return get(/databases/$(db)/documents/penukaran/$(id)).data;
    }

    function penukaranAfter(id) {
      return getAfter(/databases/$(db)/documents/penukaran/$(id)).data;
    }

    function userBefore(uid) {
      return get(/databases/$(db)/documents/users/$(uid)).data;
    }

    function userAfter(uid) {
      return getAfter(/databases/$(db)/documents/users/$(uid)).data;
    }

    // ---------- users ----------
    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isOps());
      allow list: if isOps(); // pencarian warga oleh ops

      // Self-registrasi warga: role wajib "warga", saldo wajib 0
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(
             ['role', 'nama', 'noHp', 'alamat', 'email', 'namaLower', 'saldoPoin', 'createdAt'])
        && request.resource.data.role == 'warga'
        && request.resource.data.saldoPoin == 0
        && request.resource.data.nama is string
        && request.resource.data.nama.size() > 0
        && request.resource.data.nama.size() <= 100
        && request.resource.data.namaLower == request.resource.data.nama.lower();

      // role & profil tidak bisa diubah siapa pun; saldo hanya lewat 2 jalur di bawah
      allow update: if opsTambahSaldo(uid) || wargaKurangiSaldo(uid);

      allow delete: if false;

      // Jalur 1: ops menambah saldo, delta HARUS sama dengan totalPoin dokumen
      // setoran BARU (lastTxnId) yang dibuat di transaction yang sama.
      function opsTambahSaldo(uid) {
        return isOps()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['saldoPoin', 'lastTxnId'])
          && request.resource.data.lastTxnId is string
          // dokumen setoran harus BARU dibuat di batch ini (anti-replay)
          && !exists(/databases/$(db)/documents/setoran/$(request.resource.data.lastTxnId))
          && setoranAfter(request.resource.data.lastTxnId).wargaId == uid
          && setoranAfter(request.resource.data.lastTxnId).opsId == request.auth.uid
          && request.resource.data.saldoPoin
             == resource.data.saldoPoin + setoranAfter(request.resource.data.lastTxnId).totalPoin;
      }

      // Jalur 2: warga mengurangi saldonya sendiri, delta HARUS sama dengan
      // poinDitukar dari penukaran yang berubah pending→confirmed di transaction
      // yang sama (validasi delta, bukan percaya angka client).
      function wargaKurangiSaldo(uid) {
        return signedIn() && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['saldoPoin', 'lastTxnId'])
          && request.resource.data.lastTxnId is string
          && penukaranBefore(request.resource.data.lastTxnId).status == 'pending'
          && penukaranAfter(request.resource.data.lastTxnId).status == 'confirmed'
          && penukaranAfter(request.resource.data.lastTxnId).wargaId == uid
          && request.resource.data.saldoPoin
             == resource.data.saldoPoin - penukaranBefore(request.resource.data.lastTxnId).poinDitukar
          && request.resource.data.saldoPoin >= 0;
      }
    }

    // ---------- jenisSampah (master data) ----------
    match /jenisSampah/{id} {
      allow read: if signedIn(); // transparansi tarif untuk semua user login
      allow create, update: if isOps()
        && request.resource.data.nama is string
        && request.resource.data.nama.size() > 0
        && request.resource.data.nama.size() <= 100
        && request.resource.data.kategori in ['organik', 'anorganik', 'b3']
        && request.resource.data.poinPerKg is int
        && request.resource.data.poinPerKg > 0;
      allow delete: if isOps();
    }

    // ---------- setoran ----------
    // Rules tidak punya loop: jumlahkan poin item secara manual, maksimal 10 item.
    function itemPoin(items, i) {
      return i < items.size() ? items[i].poin : 0;
    }

    function totalItemPoin(items) {
      return itemPoin(items, 0) + itemPoin(items, 1) + itemPoin(items, 2)
        + itemPoin(items, 3) + itemPoin(items, 4) + itemPoin(items, 5)
        + itemPoin(items, 6) + itemPoin(items, 7) + itemPoin(items, 8)
        + itemPoin(items, 9);
    }

    match /setoran/{id} {
      allow read: if signedIn() && (resource.data.wargaId == request.auth.uid || isOps());

      allow create: if isOps()
        && request.resource.data.opsId == request.auth.uid
        && request.resource.data.items is list
        && request.resource.data.items.size() >= 1
        && request.resource.data.items.size() <= 10
        && request.resource.data.totalPoin is int
        && request.resource.data.totalPoin > 0
        && request.resource.data.totalPoin == totalItemPoin(request.resource.data.items)
        // saldo warga harus ikut bertambah persis totalPoin di batch yang sama
        && userAfter(request.resource.data.wargaId).saldoPoin
           == userBefore(request.resource.data.wargaId).saldoPoin + request.resource.data.totalPoin;

      allow update, delete: if false; // setoran tidak bisa diedit/dihapus (audit trail)
    }

    // ---------- penukaran ----------
    match /penukaran/{id} {
      allow read: if signedIn() && (resource.data.wargaId == request.auth.uid || isOps());

      // Ops membuat permintaan penukaran: pending, token acak, expire ≤ 5 menit,
      // saldo warga harus cukup saat dibuat.
      // Aturan uang (samakan dengan konstanta di Repo.kt):
      // minimal pencairan 50 poin, nilai tukar 1 poin = Rp 200.
      allow create: if isOps()
        && request.resource.data.opsId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.poinDitukar is int
        && request.resource.data.poinDitukar >= 50
        && request.resource.data.jumlahRupiah == request.resource.data.poinDitukar * 200
        && request.resource.data.poinDitukar <= userBefore(request.resource.data.wargaId).saldoPoin
        && request.resource.data.qrToken is string
        && request.resource.data.qrToken.size() >= 16
        && request.resource.data.confirmedAt == null
        && request.resource.data.tokenExpiredAt is timestamp
        && request.resource.data.tokenExpiredAt > request.time
        && request.resource.data.tokenExpiredAt <= request.time + duration.value(5, 'm');

      allow update: if wargaKonfirmasi() || opsBatalkan();

      allow delete: if false;

      // Warga (pemilik, email terverifikasi) konfirmasi hasil scan QR:
      // pending → confirmed, belum expire, hanya status+confirmedAt yang berubah,
      // dan saldo warga berkurang persis poinDitukar di transaction yang sama.
      function wargaKonfirmasi() {
        return signedIn()
          && request.auth.uid == resource.data.wargaId
          && request.auth.token.email_verified == true
          && resource.data.status == 'pending'
          && request.time < resource.data.tokenExpiredAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'confirmedAt'])
          && request.resource.data.status == 'confirmed'
          && request.resource.data.confirmedAt == request.time
          && userAfter(resource.data.wargaId).saldoPoin
             == userBefore(resource.data.wargaId).saldoPoin - resource.data.poinDitukar;
      }

      // Ops membatalkan permintaan yang masih pending (mis. token keburu expire).
      function opsBatalkan() {
        return isOps()
          && resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status == 'cancelled';
      }
    }

    // ---------- leaderboard (proyeksi publik: hanya nama + poin per musim) ----------
    // Ditulis HANYA oleh ops saat setoran; tidak berkurang saat penukaran.
    // Reset tiap kuartal lewat pergantian docId musim. Tak ada data privat di sini.
    match /leaderboard/{docId} {
      allow read: if signedIn();
      allow write: if isOps();
    }

    // Default: semua koleksi lain ditolak.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
